import cv2

cap = cv2.VideoCapture("sample.mp4")

while cap.isOpened():

    ret, frame = cap.read()

    if not ret:
        break

    cv2.imshow("Video", frame)

    # Slow Motion
    key = cv2.waitKey(100)

    # Fast Motion: use waitKey(10)

    if key == 27:
        break

cap.release()
cv2.destroyAllWindows()
