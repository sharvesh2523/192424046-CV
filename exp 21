import cv2

img = cv2.imread("image.jpg", 0)

grad_x = cv2.Sobel(img,
                   cv2.CV_64F,
                   1,
                   0)

grad_y = cv2.Sobel(img,
                   cv2.CV_64F,
                   0,
                   1)

gradient = cv2.magnitude(grad_x,
                         grad_y)

cv2.imshow("Original", img)
cv2.imshow("Gradient Masking", gradient)

cv2.waitKey(0)
cv2.destroyAllWindows()
