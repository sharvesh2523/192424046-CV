import cv2
import numpy as np

img = cv2.imread("image.jpg")

rows, cols = img.shape[:2]

H = np.array([[1,0,0],
              [0,1,0],
              [0,0,1]],
              dtype=np.float32)

output = cv2.warpPerspective(img,
                              H,
                              (cols, rows))

cv2.imshow("Original", img)
cv2.imshow("Homography", output)

cv2.waitKey(0)
cv2.destroyAllWindows()
